# LLM provider selection
# Supported: openai, anthropic, bedrock
LLM_PROVIDER=openai

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# Bedrock (used when LLM_PROVIDER=bedrock)
BEDROCK_AWS_REGION=us-east-1
# Bedrock auth uses the standard boto3/AWS credential chain.
# The Bedrock model is currently selected in core/llm_provider.py.

# Optional supervisor override (works for openai or bedrock)
# SUPERVISOR_LLM_MODEL=gpt-5-nano
